{
  "mcpServers": {
    "dart": {
      "command": "dart",
      "args": ["mcp-server"]
    },
    "maestro": {
      "command": "maestro",
      "args": ["mcp"]
    },
    "firebase": {
      "command": "npx",
      "args": ["-y", "firebase-tools@latest", "mcp"],
      "env": {}
    },
    "clickup": {
      "url": "https://mcp.clickup.com/mcp"
    },
    "revenuecat": {
      "url": "https://mcp.revenuecat.ai/mcp",
      "headers": {
        "Authorization": "Bearer ${env:REVENUECAT_API_KEY}"
      }
    }
  }
}
