#!/usr/bin/env bash
# Unified CLI: self-update (git pull ai-resources), vendor sync, generate, IDE stubs.
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# Repo root = parent of bin/
export AGENT_KIT="${AGENT_KIT:-$(cd "$SCRIPT_DIR/.." && pwd)}"
export AGENT_SKILLS_ROOT="${AGENT_SKILLS_ROOT:-$AGENT_KIT/cursor/skills}"
export SKILL_REGISTRY_OUT="${SKILL_REGISTRY_OUT:-$AGENT_KIT/cursor/skills-registry.md}"
export SKILLS_INDEX_OUT="${SKILLS_INDEX_OUT:-$AGENT_KIT/cursor/skills-index.json}"
AK="$AGENT_KIT"

usage() {
  cat <<'EOF'
Usage: agent-kit <command> [args]

Commands:
  self-update       Git pull this repo (ai-resources) + vendor-sync + generate
  vendor-sync       Vendors from vendor-manifest.json → cursor/skills
  generate          Regenerate cursor/skills-registry.md + cursor/skills-index.json
  setup <target>    Bootstrap files for: cursor | claude | gemini | opencode | codex | vscode | all

Env:
  AGENT_KIT           Repo root (default: auto-detected from this script)
  AGENT_SKILLS_ROOT   Default: $AGENT_KIT/cursor/skills

EOF
}

cmd_self_update() {
  if [[ -d "$AK/.git" ]]; then
    echo "==> git pull $AK"
    git -C "$AK" pull --ff-only origin main 2>/dev/null || git -C "$AK" pull --ff-only || true
  else
    echo "Note: $AK is not a git clone yet — skipping pull."
  fi
  cmd_vendor_sync
  cmd_generate
  echo "==> self-update complete"
}

cmd_vendor_sync() {
  echo "==> vendor-sync → $AGENT_SKILLS_ROOT"
  python3 "$AK/scripts/vendor_sync.py"
}

cmd_generate() {
  echo "==> generate (registry + skills-index.json)"
  bash "$AK/scripts/generate-artifacts.sh"
}

setup_cursor() {
  mkdir -p "${HOME}/.cursor"
  cat > "${HOME}/.cursor/AGENT_KIT.md" <<EOF
# ai-resources (pointer)

- **Repository:** \`$AK\` — set \`export AGENT_KIT=$AK\` in shell if needed.
- **Skills / rules source:** \`$AK/cursor/\` — install step will link into \`~/.cursor\` (coming later).
- **Refresh:** \`agent-kit self-update\` from \`$AK/bin/agent-kit\`
EOF
  echo "Wrote ${HOME}/.cursor/AGENT_KIT.md"
}

setup_claude() {
  mkdir -p "${HOME}/.claude"
  cat > "${HOME}/.claude/CLAUDE.md" <<EOF
# ai-resources (Claude Code)

1. **Repo:** \`$AK\`
2. **Skills:** \`$AK/cursor/skills\` — set \`export AGENT_SKILLS_ROOT=$AK/cursor/skills\`
3. **Indexes:** \`$AK/cursor/skills-registry.md\`, \`$AK/cursor/skills-index.json\`

Run: \`$AK/bin/agent-kit self-update\` after clone/pull.
EOF
  echo "Wrote ${HOME}/.claude/CLAUDE.md"
}

setup_gemini() {
  mkdir -p "${HOME}/.gemini"
  cat > "${HOME}/.gemini/GEMINI.md" <<EOF
# ai-resources (Gemini)

Repo: \`$AK\` — Skills: \`$AK/cursor/skills\` — Index: \`$AK/cursor/skills-index.json\`
EOF
  echo "Wrote ${HOME}/.gemini/GEMINI.md"
}

setup_opencode() {
  mkdir -p "${HOME}/.config/opencode"
  cat > "${HOME}/.config/opencode/AGENT_KIT.md" <<EOF
# ai-resources (OpenCode)

Repo: \`$AK\` — \`$AK/cursor/skills-registry.md\`
EOF
  echo "Wrote ${HOME}/.config/opencode/AGENT_KIT.md"
}

setup_codex() {
  mkdir -p "${HOME}/.codex"
  cat > "${HOME}/.codex/AGENTS.md" <<EOF
# ai-resources (Codex)

Repo: \`$AK\` — Discovery: \`$AK/cursor/skills-index.json\`
EOF
  echo "Wrote ${HOME}/.codex/AGENTS.md"
}

setup_vscode() {
  mkdir -p "${HOME}/.vscode"
  cat > "${HOME}/.vscode/copilot-instructions.md" <<EOF
# ai-resources (Copilot)

Skills: \`$AK/cursor/skills\` — \`$AK/README.md\`
EOF
  echo "Wrote ${HOME}/.vscode/copilot-instructions.md"
}

cmd_setup() {
  local t="${1:-}"
  case "$t" in
    cursor) setup_cursor ;;
    claude) setup_claude ;;
    gemini) setup_gemini ;;
    opencode) setup_opencode ;;
    codex) setup_codex ;;
    vscode) setup_vscode ;;
    all)
      setup_cursor
      setup_claude
      setup_gemini
      setup_opencode
      setup_codex
      setup_vscode
      ;;
    *)
      echo "Unknown target: $t" >&2
      usage
      exit 1
      ;;
  esac
}

case "${1:-}" in
  self-update) cmd_self_update ;;
  vendor-sync) cmd_vendor_sync ;;
  generate) cmd_generate ;;
  setup) cmd_setup "${2:-}" ;;
  ""|-h|--help) usage ;;
  *)
    echo "Unknown command: $1" >&2
    usage
    exit 1
    ;;
esac
